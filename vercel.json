{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=UTF-8" }]
    },
    {
      "source": "/sitemap-pages.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=UTF-8" }]
    },
    {
      "source": "/sitemap-blog.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=UTF-8" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=UTF-8" }]
    }
  ],
  "rewrites": [
    { "source": "/docs", "destination": "/docs/" }
  ],
  "trailingSlash": false
}
