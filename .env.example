# ══════════════════════════════════════════════
#  IndexFast — .env
#  Скопіюй у .env і заповни свої значення
#  НІКОЛИ не комітити .env в git!
# ══════════════════════════════════════════════

# ── App
APP_URL=https://indexfast.pp.ua
APP_ENV=production

# ── Database (MySQL/MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=indexfast
DB_USER=indexfast_user
DB_PASS=STRONG_DB_PASSWORD_HERE

# ── JWT (мінімум 32 символи, випадковий рядок)
# Генерація: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── Google OAuth 2.0
# 1. Відкрий: https://console.cloud.google.com/
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized redirect URIs: https://indexfast.pp.ua/api/auth/google/callback.php
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ── SMTP Email
# Gmail: увімкни "App Password" в налаштуваннях Google акаунту
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_16_chars

MAIL_FROM=noreply@indexfast.pp.ua
MAIL_FROM_NAME=IndexFast
