# ══════════════════════════════════════════════
#  IndexFast — .env
#  Скопіюй у .env і заповни свої значення
#  НІКОЛИ не додавати .env в git!
# ══════════════════════════════════════════════

# ── App
APP_URL=https://indexfast.pp.ua
APP_ENV=production                  # production | development

# ── Database (MySQL 8.0+)
# Hostinger: Settings → Databases → знайди назву, юзера і пароль
DB_HOST=localhost
DB_PORT=3306
DB_NAME=indexfast_db
DB_USER=indexfast_user
DB_PASS=STRONG_PASSWORD_HERE

# ── JWT
# Генерація: openssl rand -hex 32
# Або: https://generate-secret.vercel.app/32
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARS_RANDOM_STRING_HERE

# ── Google OAuth 2.0 (для кнопки "Увійти через Google")
# 1. https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Authorized redirect URIs: https://indexfast.pp.ua/api/auth/google/callback.php
# Якщо не потрібен Google OAuth — залиш порожнім
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMTP Email (для підтвердження email і скидання пароля)
# Gmail: Google Account → Security → App Passwords → Generate
# Або використай сервіс: Brevo, Mailgun, SendGrid (є безкоштовні плани)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx     # 16-символьний App Password

MAIL_FROM=noreply@indexfast.pp.ua
MAIL_FROM_NAME=IndexFast

# ── Моніторинг воркера (опціонально)
# Якщо заповнено — health.php надсилатиме Telegram алерти при збоях
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Діагностика БД (db_check.php)
# Після деплою відкрий: https://indexfast.pp.ua/api/db_check.php?token=ТУТ_СЕКРЕТ
# Після перевірки — видали db_check.php або залиш порожнім
DB_CHECK_TOKEN=
